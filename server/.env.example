JWT_SECRET=your_super_secret_jwt_key_change_this
ADMIN_PASSWORD=mvr@123
PORT=3000
NODE_ENV=production
DATA_DIR=/var/lib/mvr_data

# Google Drive Storage Config (Service Account fallback)
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
GOOGLE_DRIVE_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"..."}

# Google Drive Storage Config (OAuth2 User - recommended to bypass quota limits)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

